# Copy to .env. NEVER commit .env.

PORT=3000

# 'embedded'  → PGlite (in-process Postgres) + in-memory KV + disk blobs. Zero Docker.
# 'external'  → real Postgres + Redis + MinIO/S3 from docker-compose.
ADAPTERS=embedded

# Where embedded mode keeps its state (PGlite files, uploaded media)
DATA_DIR=./data

JWT_SECRET=dev-secret-change-me-32-bytes-minimum!!
JWT_ACCESS_TTL_MIN=15
REFRESH_TTL_DAYS=30

# mock → OTP code is logged AND returned in the API response (dev only!)
OTP_MODE=mock

# External-adapter settings (ignored in embedded mode)
DATABASE_URL=postgres://dcom:dcom_dev_pw@localhost:5432/dcom
REDIS_URL=redis://localhost:6379
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=media
S3_ACCESS_KEY=minio_dev
S3_SECRET_KEY=minio_dev_pw

# WebRTC ICE servers handed to clients. Empty = host candidates only (fine for
# same-machine/same-LAN testing). Point at coturn/public STUN for real networks.
STUN_URL=
TURN_URL=
TURN_USER=
TURN_PASS=

{
  "name": "@dcom/gateway",
  "version": "0.1.0",
  "description": "REST API + WebSocket gateway. NestJS modular monolith over ports-and-adapters.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start:dev": "tsc -p tsconfig.json --incremental && node dist/apps/gateway/src/main.js",
    "start:staging": "node dist/apps/gateway/src/main.js",
    "test": "node --experimental-vm-modules ../../node_modules/jest/bin/jest.js"
  },
  "dependencies": {
    "@dcom/shared": "file:../../packages/shared",
    "@electric-sql/pglite": "^0.2.0",
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "web-push": "^3.6.7",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.0",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.5.10",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.5.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/test"
    ],
    "testTimeout": 30000,
    "moduleNameMapper": {
      "^@dcom/shared$": "<rootDir>/../../packages/shared/src/index.ts"
    }
  }
}
